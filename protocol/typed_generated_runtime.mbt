///|
pub(all) struct RuntimeConsoleAPICalledEventParams {
  type_ : String
  args : Array[RuntimeRemoteObject]
  execution_context_id : RuntimeExecutionContextId
  timestamp : RuntimeTimestamp
  stack_trace : RuntimeStackTrace?
  context : String?
} derive(Eq, Debug)

///|
pub fn RuntimeConsoleAPICalledEventParams::to_json(
  self : RuntimeConsoleAPICalledEventParams,
) -> Json {
  let fields : Map[String, Json] = {}
  fields["type"] = Json::string(self.type_)
  fields["args"] = Json::array(self.args.map(item => item.to_json()))
  fields["executionContextId"] = self.execution_context_id.to_json()
  fields["timestamp"] = self.timestamp.to_json()
  if self.stack_trace is Some(value) {
    fields["stackTrace"] = value.to_json()
  }
  if self.context is Some(value) {
    fields["context"] = Json::string(value)
  }
  Json::object(fields)
}

///|
pub fn RuntimeConsoleAPICalledEventParams::from_json(
  params : Json,
) -> RuntimeConsoleAPICalledEventParams raise ProtocolSchemaError {
  let method_name = "Runtime.consoleAPICalled"
  ignore(cdp_schema_event(method_name~, params~))
  let fields = typed_json_fields(method_name, params)
  {
    type_: typed_required_string(method_name, fields, "type", "string"),
    args: typed_param_array(
      method_name,
      typed_required_json(method_name, fields, "args"),
      "args",
      "array<RemoteObject>",
    ).map(item => RuntimeRemoteObject::from_json(item)),
    execution_context_id: RuntimeExecutionContextId::from_json(
      typed_required_json(method_name, fields, "executionContextId"),
    ),
    timestamp: RuntimeTimestamp::from_json(
      typed_required_json(method_name, fields, "timestamp"),
    ),
    stack_trace: match typed_optional_json(fields, "stackTrace") {
      Some(value) => Some(RuntimeStackTrace::from_json(value))
      None => None
    },
    context: typed_optional_string(method_name, fields, "context", "string"),
  }
}

