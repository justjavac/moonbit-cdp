    data: InputDragData::from_json(
      typed_required_json(method_name, fields, "data"),
    ),
  }
}

///|
pub fn input_drag_intercepted_event(
  params : InputDragInterceptedEventParams,
  session_id? : String,
) -> CdpEventMessage raise ProtocolSchemaError {
  cdp_schema_event(
    method_name="Input.dragIntercepted",
    params=params.to_json(),
    session_id?,
  )
}
